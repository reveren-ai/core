{
  "name": "@reveren-ai/core",
  "version": "0.1.0-alpha.1",
  "description": "reveren — structured, versioned guardrails for AI coding agents. One pipeline. Every agent.",
  "keywords": [
    "reveren",
    "protocols",
    "agents",
    "ai",
    "cli",
    "claude",
    "cursor",
    "copilot",
    "windsurf"
  ],
  "homepage": "https://reveren.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/reveren-ai/core.git"
  },
  "bugs": {
    "url": "https://github.com/reveren-ai/core/issues"
  },
  "license": "BUSL-1.1",
  "author": "Innocent Muisha <innocent@muisha.com>",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "rvr": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "protocols",
    "docs",
    "MANIFESTO.md",
    "LICENSE",
    "LICENSE-ADDITIONAL-GRANT.txt",
    "LICENSE.protocols"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "pretest:integration": "tsup",
    "pre-push": "pnpm typecheck && pnpm test:run",
    "prepare": "husky"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^12.1.0",
    "find-up": "^7.0.0",
    "jiti": "^2.4.0",
    "picocolors": "^1.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@types/node": "^20.16.0",
    "@vitest/coverage-v8": "^2.1.0",
    "husky": "^9.1.7",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
